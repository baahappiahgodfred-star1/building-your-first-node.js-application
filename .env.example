# Example .env file for emailSender.js
# Copy to .env and fill values (do NOT commit real credentials)

SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_FROM=your-email@gmail.com
SMTP_TO=recipient@example.com
SMTP_SUBJECT=Hello from Node.js
SMTP_TEXT=Hello world!
SMTP_HTML=<b>Hello world!</b>
